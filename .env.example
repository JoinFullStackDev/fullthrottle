# =============================================================================
# FullThrottle AI — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Runtime Mode ("direct-llm" for live agents, "stub" for placeholder)
RUNTIME_MODE=direct-llm

# LLM Providers
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Google Drive OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Site URL (used for invite email redirects, OAuth callbacks)
# Set to http://localhost:3000 for local dev, your staging/prod URL for deployment
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Clutch System User (optional — set before running seed to use a specific password)
# If not set, seed route auto-generates a password and returns it in the response
# CLUTCH_SYSTEM_PASSWORD=
